# opr-mcp environment configuration
#
# Every variable read by the application is listed here. All are optional
# unless marked (required). Defaults shown match production code; uncomment
# to override. See README.md "Configuration" for the full reference.

# === Core paths & logging ===
# Content SQLite file (rules, units, chunks, vectors).
# DB_PATH=~/.local/share/opr-mcp/opr.db

# OAuth / Discord-token SQLite file. Kept separate so a content-DB rebuild
# doesn't drop registered clients or issued tokens.
# AUTH_DB_PATH=~/.local/share/opr-mcp/auth.db

# Standard Python logging level.
# LOG_LEVEL=INFO

# Override the markdown injected into the first tool response per MCP session.
# INSTRUCTIONS_FILE=

# === HTTP server (only for --transport http or AUTH_ENABLED=true) ===
# HOST=127.0.0.1
# PORT=8765

# === PDF ingest ===
# Directory of user-supplied PDFs (typically the advanced-rules PDF).
# Ingested at startup, watched for changes, created if missing.
# PDF_DIR=/pdf

# Have the PDF parser also write to units / unit_upgrades. Off by default —
# Forge JSON is the canonical source. Turn on as a fallback for books not on Forge.
# PDF_PARSE_UNIT_BLOCKS=false

# === Embeddings ===
# Override the embedding model. Must produce 384-dim vectors.
# EMBED_MODEL=BAAI/bge-small-en-v1.5

# Torch device: cpu, cuda, mps.
# EMBED_DEVICE=cpu

# === Forge sync (default: JSON-only, runs at startup + every 12h) ===
# Run the JSON detail sync. Set to false / 0 / no / off to disable.
# FORGE_SYNC=true

# Additionally mirror army-book PDFs into <PDF_DIR>/forge/ for full-text indexing.
# FORGE_DOWNLOAD_PDFS=false

# Background scheduler interval (seconds). Minimum 60.
# FORGE_INTERVAL_SECONDS=43200

# Comma-separated: official, community, or both.
# FORGE_FILTERS=official

# Comma-separated game-system slugs / numeric IDs, or "all".
# Known slugs: ftl,gf,gff,aof,aofs,aofr,aofq,aofqai,gfsq,gfsqai
# FORGE_GAMES=gf,aof

# Explicit destination for downloaded PDFs (only used with FORGE_DOWNLOAD_PDFS=true).
# Defaults to <PDF_DIR>/forge if PDF_DIR is set, else a 'forge-pdfs' folder under
# the platform user data dir.
# FORGE_PDF_DIR=

# Minimum spacing between outbound Forge / CDN requests (seconds).
# FORGE_MIN_REQUEST_INTERVAL_SECONDS=3.0

# === Retention (only active when FORGE_SYNC=true) ===
# How often the retention sweeper runs (seconds). Minimum 60.
# CLEANUP_INTERVAL_SECONDS=86400

# === Auth (Discord OAuth) — required for remote HTTP deployment ===
# Enable Discord OAuth 2.1 authentication for the HTTP transport.
# AUTH_ENABLED=false

# Public-facing URL of this server. https:// required (http:// only allowed
# for localhost / 127.0.0.1).
AUTH_PUBLIC_URL=

# Encryption secret for tokens. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
AUTH_SECRET=

# Token lifetimes (seconds).
# AUTH_TOKEN_TTL_SECONDS=3600
# AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# Discord application credentials (developer portal).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord server (guild) whose members are allowed to authenticate.
DISCORD_GUILD_ID=
